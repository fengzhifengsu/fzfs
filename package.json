    "commander": "^12.0.0",
    "chalk": "^5.3.0",
    "openai": "^4.28.0",
    "@anthropic-ai/sdk": "^0.18.0",
    "playwright": "^1.41.0",
    "cheerio": "^1.0.0-rc.12",
    "uuid": "^9.0.0",
    "yaml": "^2.3.4",
    "fs-extra": "^11.2.0",
    "chokidar": "^3.5.3",
    "winston": "^3.11.0",
